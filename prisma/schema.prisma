// ---------------------------------------------------------------------------
// Scouting models — professional tournament data from Liquipedia
// ---------------------------------------------------------------------------

model ScoutingTournament {
  id        Int              @id @default(autoincrement())
  title     String           @unique
  sourceUrl String
  mapPool   Json
  matches   ScoutingMatch[]
  rosters   ScoutingRoster[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model ScoutingMatch {
  id             Int                 @id @default(autoincrement())
  tournamentId   Int
  team1          String
  team1FullName  String
  team2          String
  team2FullName  String
  team1Score     Int?
  team2Score     Int?
  bestOf         Int
  winner         String
  winnerFullName String
  matchDate      DateTime
  mvp            String?
  vods           Json                @default("[]")
  matchRoomUrl   String?
  maps           ScoutingMapResult[]
  tournament     ScoutingTournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([tournamentId])
  @@index([team1, team2])
}

model ScoutingMapResult {
  id              Int                      @id @default(autoincrement())
  matchId         Int
  gameNumber      Int
  mapType         MapType
  mapName         String
  team1Score      String
  team2Score      String
  winner          String
  team1Comp       String[]                 @default([])
  team2Comp       String[]                 @default([])
  heroBans        ScoutingHeroBan[]
  heroAssignments ScoutingHeroAssignment[]
  match           ScoutingMatch            @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([matchId])
  @@index([mapName])
}

model ScoutingHeroBan {
  id          Int               @id @default(autoincrement())
  mapResultId Int
  team        String
  hero        String
  banOrder    Int
  mapResult   ScoutingMapResult @relation(fields: [mapResultId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([mapResultId])
  @@index([hero])
}

model ScoutingHeroAssignment {
  id          Int               @id @default(autoincrement())
  mapResultId Int
  team        String
  heroName    String
  playerName  String
  mapResult   ScoutingMapResult @relation(fields: [mapResultId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([mapResultId, team, heroName])
  @@index([mapResultId])
  @@index([playerName])
}

enum RosterCategory {
  player
  staff
  substitute
}

enum RosterRole {
  DPS
  Tank
  Support
  Flex
  Coach
  HeadCoach
  AssistantCoach
  Manager
  AssistantManager
  TeamManager
  Analyst
  PerformanceCoach
  Substitute
}

model ScoutingRoster {
  id           Int                    @id @default(autoincrement())
  tournamentId Int
  teamName     String
  tournament   ScoutingTournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  players      ScoutingRosterPlayer[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@unique([tournamentId, teamName])
  @@index([tournamentId])
  @@index([teamName])
}

model ScoutingRosterPlayer {
  id          Int            @id @default(autoincrement())
  rosterId    Int
  name        String
  displayName String
  role        RosterRole
  country     String
  didNotPlay  Boolean        @default(false)
  category    RosterCategory
  roster      ScoutingRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([rosterId])
  @@index([displayName])
}

model ScoutingPlayer {
  id              Int      @id @default(autoincrement())
  name            String
  team            String
  status          String
  role            String
  country         String
  signatureHeroes String[]
  winnings        Int      @default(0)
  region          String
  playerUrl       String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([name])
  @@index([team])
  @@index([region])
}

model ChatConversation {
  id        String   @id @default(cuid())
  userId    String
  title     String
  messages  Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ChatReport {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MapCalibration {
  id          Int                    @id @default(autoincrement())
  mapName     String                 @unique
  imageUrl    String
  imageWidth  Int
  imageHeight     Int
  displayImageKey String?
  affineA         Float?
  affineB     Float?
  affineC     Float?
  affineD     Float?
  affineTx    Float?
  affineTy    Float?
  createdBy   String
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  anchors     MapCalibrationAnchor[]
}

model MapCalibrationAnchor {
  id            Int            @id @default(autoincrement())
  calibrationId Int
  worldX        Float
  worldY        Float
  imageU        Float
  imageV        Float
  label         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  calibration   MapCalibration @relation(fields: [calibrationId], references: [id], onDelete: Cascade)

  @@index([calibrationId])
}

// Tournament Models

model Tournament {
  id        Int              @id @default(autoincrement())
  name      String
  format    TournamentFormat
  bestOf    Int              @default(3)
  playoffBestOf       Int?
  teamSlots Int              @default(8)
  status    TournamentStatus @default(DRAFT)
  startDate DateTime?
  endDate             DateTime?
  grandFinalReset     Boolean          @default(true)
  advancingTeams      Int?
  creatorId String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  teams     TournamentTeam[]
  rounds    TournamentRound[]
  matches   TournamentMatch[]

  @@index([creatorId])
}

model TournamentTeam {
  id             Int               @id @default(autoincrement())
  tournamentId   Int
  teamId         Int?
  name           String
  seed           Int
  eliminated     Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  tournament     Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team           Team?             @relation(fields: [teamId], references: [id])
  matchesAsTeam1 TournamentMatch[] @relation("MatchTeam1")
  matchesAsTeam2 TournamentMatch[] @relation("MatchTeam2")
  matchesWon     TournamentMatch[] @relation("MatchWinner")

  @@unique([tournamentId, seed])
  @@index([tournamentId])
  @@index([teamId])
}

model TournamentRound {
  id           Int               @id @default(autoincrement())
  tournamentId Int
  roundNumber  Int
  roundName    String
  bestOf       Int?
  bracket      BracketSide       @default(WINNERS)
  tournament   Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matches      TournamentMatch[]

  @@unique([tournamentId, bracket, roundNumber])
  @@index([tournamentId])
}

model TournamentMatch {
  id              Int                   @id @default(autoincrement())
  tournamentId    Int
  roundId         Int
  bracketPosition Int
  team1Id         Int?
  team2Id         Int?
  winnerId        Int?
  team1Score      Int                   @default(0)
  team2Score      Int                   @default(0)
  status          TournamentMatchStatus @default(UPCOMING)
  scheduledAt     DateTime?
  scrimId         Int?                  @unique
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  tournament      Tournament            @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  round           TournamentRound       @relation(fields: [roundId], references: [id], onDelete: Cascade)
  team1           TournamentTeam?       @relation("MatchTeam1", fields: [team1Id], references: [id])
  team2           TournamentTeam?       @relation("MatchTeam2", fields: [team2Id], references: [id])
  winner          TournamentTeam?       @relation("MatchWinner", fields: [winnerId], references: [id])
  scrim           Scrim?                @relation(fields: [scrimId], references: [id])
  maps            TournamentMap[]

  @@index([tournamentId])
  @@index([roundId])
  @@index([team1Id])
  @@index([team2Id])
}

model TournamentMap {
  id             Int             @id @default(autoincrement())
  matchId        Int
  gameNumber     Int
  mapId          Int?
  winnerOverride String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  match          TournamentMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  map            Map?            @relation(fields: [mapId], references: [id])

  @@unique([matchId, gameNumber])
  @@index([matchId])
  @@index([mapId])
}

enum AvailabilityIntervalType {
  WEEKLY
}

model TeamAvailabilitySettings {
  id                  String                   @id @default(cuid())
  teamId              Int                      @unique
  intervalType        AvailabilityIntervalType @default(WEEKLY)
  slotMinutes         Int                      @default(30)
  hoursStart          Int                      @default(12)
  hoursEnd            Int                      @default(24)
  timezone            String                   @default("America/New_York")
  weekStartsOn        Int                      @default(0)
  reminderEnabled     Boolean                  @default(true)
  reminderDayOfWeek   Int                      @default(0)
  reminderHour        Int                      @default(12)
  reminderMinute      Int                      @default(0)
  reminderRoleId      String?
  reminderGuildId     String?
  reminderChannelId   String?
  lastReminderFiredAt DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  team                Team                     @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model AvailabilitySchedule {
  id        String   @id @default(cuid())
  teamId    Int
  weekStart DateTime
  weekEnd   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team      Team                   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  responses AvailabilityResponse[]

  @@unique([teamId, weekStart])
  @@index([teamId])
}

model AvailabilityResponse {
  id              String   @id @default(cuid())
  scheduleId      String
  nameKey         String
  displayName     String
  userId          String?
  passwordHash    String?
  slots           Int[]
  submittedFromTz String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  schedule AvailabilitySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user     User?                @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([scheduleId, nameKey])
  @@index([scheduleId])
  @@index([userId])
}

model UserCredits {
  userId                   String  @id
  balanceCents             Int     @default(0)
  autoRefillEnabled        Boolean @default(false)
  autoRefillThresholdCents Int     @default(200)
  autoRefillAmountCents    Int     @default(1000)
  stripePaymentMethodId    String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum CreditTransactionType {
  TOPUP
  AUTO_REFILL
  CHARGE
  REFUND
  ADJUSTMENT
}

model CreditTransaction {
  id                Int                   @id @default(autoincrement())
  userId            String
  type              CreditTransactionType
  amountCents       Int
  balanceAfterCents Int
  description       String
  stripeEventId     String?               @unique
  metadata          Json?
  createdAt         DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

