  id              Int       @id @default(autoincrement())
  scrimId         Int
  event_type      EventType @default(defensive_assist)
  match_time      Float
  player_team     String
  player_name     String
  player_hero     String
  hero_duplicated String
  MapData         MapData?  @relation(fields: [MapDataId], references: [id], onDelete: Cascade)
