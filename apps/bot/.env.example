# Example environment variables for the Parsertime Discord bot (apps/bot).
# Copy this file to `.env` and fill in your own values. Do not commit `.env`.
# The bot runs on Bun and is deployed on Railway.

# ---------------------------------------------------------------------------
# Discord
# ---------------------------------------------------------------------------
# Bot token from the Discord developer portal.
# https://discord.com/developers/applications
DISCORD_TOKEN=
# Guild (server) ID used to register slash commands instantly during local
# development. Leave unset in production to register commands globally.
DEV_GUILD_ID=

# ---------------------------------------------------------------------------
# Database (Postgres)
# ---------------------------------------------------------------------------
# Connection string for the shared Parsertime database the bot reads from.
DATABASE_URL=

# ---------------------------------------------------------------------------
# Parsertime web app integration
# ---------------------------------------------------------------------------
# Base URL of the Parsertime web app's API, and the shared secret used to
# authenticate requests between the bot and the web app. The secret must match
# BOT_SECRET in apps/web.
PARSERTIME_API_URL=
BOT_SECRET=

# ---------------------------------------------------------------------------
# Observability (Axiom) — optional
# ---------------------------------------------------------------------------
AXIOM_OTEL_TOKEN=
AXIOM_OTEL_DATASET=
