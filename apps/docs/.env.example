# Example environment variables for the Parsertime docs site (apps/docs).
# Copy this file to `.env` and fill in your own values. Do not commit `.env`.
# Both variables are optional — the site falls back to sensible defaults.

# Vercel Edge Config connection string, used to read live update banners.
# If unset, the docs fall back to no banner.
EDGE_CONFIG=

# Public base URL of the docs site, used for metadata and canonical URLs.
# Defaults to https://docs.parsertime.app when unset.
NEXT_PUBLIC_SITE_URL=
