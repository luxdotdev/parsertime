# Example environment variables for the Parsertime web app (apps/web).
# Copy this file to `.env` and fill in your own values. Do not commit `.env`.
#
# Tip: most of these are already configured on Vercel — you can pull them with
#   vercel env pull apps/web/.env.local
# and only fill in the local-only extras (e.g. STRIPE_WEBHOOK_SECRET_LOCAL).

# ---------------------------------------------------------------------------
# Database (Postgres)
# ---------------------------------------------------------------------------
# Runtime connection used by the app through the Prisma pg driver adapter
# (src/lib/prisma.ts). Use the pooled connection string here.
DATABASE_URL=
# Direct (non-pooled) connection. Prisma CLI commands — generate, migrate,
# db push — use this for migrations. See prisma.config.ts.
DIRECT_URL=

# ---------------------------------------------------------------------------
# Vercel storage
# ---------------------------------------------------------------------------
# Vercel Blob read/write token. https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=
# Vercel Edge Config connection string. https://vercel.com/docs/storage/edge-config
EDGE_CONFIG=
# Vercel KV (Redis) — used for rate limiting and ephemeral state.
# https://vercel.com/docs/storage/vercel-kv
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# OAuth provider credentials.
# GitHub:  https://docs.github.com/en/developers/apps/creating-an-oauth-app
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Discord: https://discord.com/developers/docs/topics/oauth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Google:  https://developers.google.com/identity/protocols/oauth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Auth secret + base URL. Better Auth reads BETTER_AUTH_SECRET / BETTER_AUTH_URL
# and falls back to these NEXTAUTH_* values when the BETTER_AUTH_* vars are unset.
NEXTAUTH_SECRET=
NEXTAUTH_URL=
# Optional Better Auth overrides (default to the NEXTAUTH_* values above).
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=

# ---------------------------------------------------------------------------
# Stripe (subscriptions + AI credits)
# ---------------------------------------------------------------------------
# https://docs.stripe.com/keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Webhook signing secret printed by `stripe listen` for local development.
STRIPE_WEBHOOK_SECRET_LOCAL=

# ---------------------------------------------------------------------------
# Email (AWS SES)
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_REGION=

# ---------------------------------------------------------------------------
# Object storage (Cloudflare R2)
# ---------------------------------------------------------------------------
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=

# ---------------------------------------------------------------------------
# Discord bot integration (apps/bot)
# ---------------------------------------------------------------------------
# Base URL of the Parsertime Discord bot's HTTP API, and the shared secret used
# to authenticate requests between the web app and the bot.
BOT_API_URL=
BOT_SECRET=

# ---------------------------------------------------------------------------
# FACEIT scouting
# ---------------------------------------------------------------------------
# https://developers.faceit.com/
FACEIT_API_KEY=
# Shared secret used to verify incoming FACEIT match webhooks.
FACEIT_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Notifications & bug reporting
# ---------------------------------------------------------------------------
# Discord webhook for general notifications.
# https://support.discord.com/hc/en-us/articles/228383668-Intro-to-Webhooks
DISCORD_WEBHOOK_URL=
# Discord webhook + role to ping when a bug report is submitted.
BUG_REPORT_WEBHOOK_URL=
BUG_REPORT_NOTIFICATIONS_ROLE_ID=

# ---------------------------------------------------------------------------
# Cron jobs
# ---------------------------------------------------------------------------
# Shared secret authorizing scheduled (cron) endpoint requests.
# https://vercel.com/docs/cron-jobs/manage-cron-jobs#securing-cron-jobs
CRON_SECRET=

# ---------------------------------------------------------------------------
# Feature flags (Vercel Flags / Flags Explorer)
# ---------------------------------------------------------------------------
# Secret used to authorize the Flags Explorer / flags discovery endpoint.
# Optional for local dev. https://flags-sdk.dev/
FLAGS_SECRET=

# ---------------------------------------------------------------------------
# Observability (Axiom) — optional for local development
# ---------------------------------------------------------------------------
AXIOM_TOKEN=
AXIOM_DATASET=
AXIOM_OTEL_TOKEN=
AXIOM_OTEL_DATASET=
AXIOM_METRICS_TOKEN=
AXIOM_METRICS_DATASET=

# ---------------------------------------------------------------------------
# Win-probability trainer (Vercel Python function: api/wp-train)
# ---------------------------------------------------------------------------
# These are consumed by the Python serverless trainer, NOT the Next.js app, so
# they are not needed to run the web app locally. They are configured on Vercel.
#   - WP_FEATURE_HASH must equal the TS featureHash() in the WP model code.
#   - PUBLISH_URL points at the publish callback: <origin>/api/cron/wp-publish.
# The trainer also reuses CRON_SECRET (above) as its bearer token.
WP_FEATURE_HASH=
PUBLISH_URL=

# ---------------------------------------------------------------------------
# Debugging — optional
# ---------------------------------------------------------------------------
# Set to "true" to render the predictive-prefetch debug overlay (visualizes the
# cursor reach, heading cone, and per-link detection state). Never shown in
# production regardless of this value.
NEXT_PUBLIC_PREFETCH_DEBUG=
