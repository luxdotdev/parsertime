{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "trailingComma": "es5",
  "tabWidth": 2,
  "semi": true,
  "singleQuote": false,
  "printWidth": 80,
  "sortTailwindcss": {},
  "sortPackageJson": false,
  "ignorePatterns": [
    "node_modules",
    "**/.next/**",
    "**/_next/**",
    "**/dist/**",
    "**/__tmp__/**",
    "lerna.json",
    ".github",
    "pnpm-lock.yaml"
  ]
}
